# ============================================================
#  Blackwood Landscaping — environment variables
#  Copy to .env.local for local dev. In production, set these
#  in the Vercel dashboard (Project → Settings → Environment
#  Variables). NEVER commit real values to git.
# ============================================================

# --- Resend (email) ---------------------------------------------------
# Get from https://resend.com/api-keys after verifying your domain.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# The "from" address. The DOMAIN here must be verified in Resend,
# otherwise mail is rejected or spam-filed. Until your domain is
# verified you can use onboarding@resend.dev for TESTING ONLY
# (it can only send to your own Resend account email).
MAIL_FROM="Blackwood Landscaping <office@blackwood-landscaping.com>"

# Where office notifications land. Can be any inbox you control.
OFFICE_INBOX=blackwoodlandscaping@yahoo.com

# --- Origin allow-list ------------------------------------------------
# Comma-separated. Submissions whose Origin/Referer don't match are
# rejected with 403. Set to your real domain(s) once deployed.
# Leave blank to disable the check (NOT recommended for production).
ALLOWED_ORIGINS=https://blackwood-landscaping.com,https://www.blackwood-landscaping.com
